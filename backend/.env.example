# Required — MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/mayvel_task?retryWrites=true&w=majority

# Required — Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Required — long random string for signing JWTs
JWT_SECRET=

# Optional — public base URL of this backend (used in emailed links)
PUBLIC_BASE_URL=https://mayvelerp.onrender.com

# Optional — SMTP for outgoing email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
